# ============================================================
# OpenRouter AI Stack - Environment Configuration
# cp .env.example .env  →  dann alle Werte ausfüllen
# ============================================================

# ── PFLICHTFELDER ────────────────────────────────────────────

# OpenRouter API Key → https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-DEIN-KEY-HIER

# Sicherheit: generieren mit: openssl rand -hex 32
REDIS_PASSWORD=SICHERES-REDIS-PASSWORT
MCP_SECRET=SICHERES-MCP-SECRET

# ── OPENROUTER KONFIGURATION ─────────────────────────────────

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# HTTP Headers für OpenRouter Tracking (optional)
HTTP_REFERER=http://localhost:8085
X_TITLE=OpenRouter AI Stack

# ── MODELLE ──────────────────────────────────────────────────
# Vision + Complex tasks
MODEL_VISION=qwen/qwen3-vl-32b-instruct
# Auch Qwen3-VL für komplexe Code-Aufgaben
MODEL_COMPLEX=qwen/qwen3-vl-32b-instruct
# Schnell + günstig für einfache Anfragen
MODEL_FAST=deepseek/deepseek-v3.2
# Fallback wenn andere Modelle nicht verfügbar
MODEL_FALLBACK=google/gemini-2.5-flash-lite

# ── ROUTING THRESHOLDS ───────────────────────────────────────

# Token-Schwelle ab der "komplex" gilt (≥ Schwelle → Qwen3-VL)
COMPLEXITY_THRESHOLD=150

# Schlüsselwörter die immer Qwen3-VL triggern (kommagetrennt)
COMPLEX_KEYWORDS=analysiere,erkläre,verarbeite,designe,optimiere,recherchiere,debugge,architecture,refactor,analyze,explain,debug,review,optimize,design

# ── PERFORMANCE ──────────────────────────────────────────────

# Redis Cache TTL in Sekunden (3600 = 1 Stunde)
CACHE_TTL=3600

# Rate Limit: Anfragen pro Minute
RATE_LIMIT_RPM=60

# ── MEMORY SERVICE ───────────────────────────────────────────

# Ähnlichkeitsschwelle für Memory-Abruf (0.0 - 1.0)
SIMILARITY_THRESHOLD=0.3

# Maximale Anzahl gespeicherter Memories
MAX_MEMORIES=10000

# Anzahl zurückgegebener relevanter Memories pro Anfrage
MEMORY_TOP_K=5

# ── COST TRACKING ────────────────────────────────────────────

COST_DB_PATH=/data/costs/cost_log.db
DASHBOARD_BUDGET_DAILY=10.00
DASHBOARD_BUDGET_WEEKLY=50.00
DASHBOARD_BUDGET_MONTHLY=150.00

# ── PORTS ────────────────────────────────────────────────────

ROUTER_PORT=8085
MEMORY_PORT=8086
MCP_PORT=8087
WEBUI_PORT=8088
OBSERVER_PORT=8089

# ── LOGGING ──────────────────────────────────────────────────

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
